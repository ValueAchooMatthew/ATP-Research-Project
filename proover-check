#!/usr/bin/env python3
"""ProoVer 2026 entry point.

Usage:
    proover-check [--time-limit SECONDS] [--quiet] PROBLEM PROOF
    proover-check [--time-limit SECONDS] [--quiet] PROOF

With a single argument the problem file is located via the proof's
"% Proof : <path>" header. Prints exactly one line to stdout:

    % SZS status VerifiedGood | VerifiedBad [: reason] | Unknown [: reason] | Timeout

Step-by-step details go to stderr unless --quiet. Exit status is always 0.
"""
import os, re, sys, threading, time


def resolve_problem(proof_path, proof_text, given):
    if given:
        return given
    m = re.search(r"%\s*Proof\s*:\s*(\S+)", proof_text)
    if not m:
        return None
    header = m.group(1)
    for candidate in (header,
                      os.path.join(os.path.dirname(os.path.abspath(proof_path)), header)):
        if os.path.exists(candidate):
            return candidate
    return header


def parse_args(argv):
    limit = float(os.environ.get("PROOVER_TIME_LIMIT", "30"))
    quiet = False
    paths = []
    i = 0
    while i < len(argv):
        a = argv[i]
        if a == "--time-limit":
            i += 1
            limit = float(argv[i])
        elif a.startswith("--time-limit="):
            limit = float(a.split("=", 1)[1])
        elif a == "--quiet":
            quiet = True
        else:
            paths.append(a)
        i += 1
    return limit, quiet, paths


def main(argv):
    start = time.monotonic()
    try:
        limit, quiet, paths = parse_args(argv)
    except (ValueError, IndexError):
        print("% SZS status Unknown : bad command line")
        return 0

    result = {}

    def work():
        try:
            sys.setrecursionlimit(1_000_000)
            import proover
            if len(paths) == 2:
                problem_path, proof_path = paths
            elif len(paths) == 1:
                problem_path, proof_path = None, paths[0]
            else:
                result["out"] = ("Unknown", "expected PROBLEM and PROOF paths")
                return
            with open(proof_path) as f:
                proof_text = f.read()
            problem_path = resolve_problem(proof_path, proof_text, problem_path)
            if not problem_path or not os.path.exists(problem_path):
                result["out"] = ("Unknown", "cannot locate the problem file")
                return
            with open(problem_path) as f:
                problem_text = f.read()
            deadline = proover.Deadline(limit - 1.0)
            deadline.start = start
            verdict, reason, _ = proover.verify(
                problem_text, proof_text, deadline,
                log_to=None if quiet else sys.stderr,
                problem_dir=os.path.dirname(os.path.abspath(problem_path)))
            result["out"] = (verdict, reason)
        except proover.OutOfTime:
            result["out"] = ("Timeout", None)
        except RecursionError:
            result["out"] = ("Unknown", "formula too deeply nested")
        except Exception as e:
            result["out"] = ("Unknown", f"{type(e).__name__}: {e}")

    sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
    threading.stack_size(512 * 1024 * 1024)
    t = threading.Thread(target=work, daemon=True)
    t.start()
    t.join(max(0.1, limit - 0.5 - (time.monotonic() - start)))

    if "out" not in result:
        verdict, reason = "Timeout", None
    else:
        verdict, reason = result["out"]
    if verdict in ("VerifiedBad", "Unknown") and reason:
        reason = " ".join(str(reason).split())
        if len(reason) > 150:
            reason = reason[:147] + "..."
        print(f"% SZS status {verdict} : {reason}")
    else:
        print(f"% SZS status {verdict}")
    sys.stdout.flush()
    os._exit(0)     # the worker may be stuck; never outlive the time limit


if __name__ == "__main__":
    main(sys.argv[1:])
